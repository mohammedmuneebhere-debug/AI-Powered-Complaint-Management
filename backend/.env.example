GROQ_API_KEY=your_groq_api_key_here

# Groq models (gemma2-9b-it was decommissioned — use current production models)
EXTRACTION_MODEL=openai/gpt-oss-20b
CHAT_MODEL=openai/gpt-oss-120b

# ── Database (pick one) ──────────────────────────────────────────────────────

# Local dev — SQLite, no setup required (default)
DATABASE_URL=sqlite:///./complaints.db

# Local PostgreSQL — run: docker compose up -d
# DATABASE_URL=postgresql://complaint_user:complaint_pass@localhost:5432/complaints_db

# Supabase — Session pooler (port 5432, recommended for SQLAlchemy / FastAPI)
# Supabase Dashboard → Project Settings → Database → Connect → Session pooler → URI
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Supabase — Transaction pooler (port 6543, higher concurrency; NullPool auto-enabled)
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres

# Supabase — Direct connection (admin / one-off migrations; not for production traffic)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Optional PostgreSQL / Supabase tuning
# DATABASE_SSL_MODE=require
# DATABASE_POOL_SIZE=5
# DATABASE_MAX_OVERFLOW=10

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
